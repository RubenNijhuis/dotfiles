.DS_Store
.idea
local/*
!local/.gitkeep
!local/machine.env.example
!local/shell-local.sh.example
!local/README.md
*.local
*.secret
.env
.claude
!config/claude/.claude/
config/claude/.claude/skills/
!config/claude/.claude/settings.json
!config/claude/.claude/statusline-command.sh

# Backups
.dotfiles-backup/

# SSH - keep config, ignore keys and sensitive data
config/ssh/.ssh/id_*
config/ssh/.ssh/*.pub
config/ssh/.ssh/known_hosts*
config/ssh/.ssh/config.d/local.conf

# Shell - machine-specific local overrides (may contain secrets)
config/shell/.config/shell/local.sh

# GPG - keep config, ignore keys and trust database
config/gpg/.gnupg/*.gpg
config/gpg/.gnupg/*.kbx
config/gpg/.gnupg/random_seed
config/gpg/.gnupg/trustdb.gpg
config/gpg/.gnupg/private-keys-v1.d/
config/gpg/.gnupg/openpgp-revocs.d/
config/gpg/.gnupg/S.*
config/gpg/.gnupg/.gpg-v21-migrated

# Vim/Neovim - keep config, ignore runtime files
config/vim/.vim/plugged/
config/vim/.vim/.netrwhist
config/vim/.config/nvim/plugged/
config/vim/.config/nvim/plugin/
config/vim/.config/nvim/.luarc.json
