#!/usr/bin/env bash
# Commit message hook enforcing conventional commit style.
set -euo pipefail

DOTFILES="$(git rev-parse --show-toplevel)"
source "$DOTFILES/lib/output.sh"

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  print_error "commit-msg hook requires a commit message file path"
  exit 1
fi

HEADER="$(head -n 1 "$MSG_FILE" | tr -d '\r')"

if [[ -z "$HEADER" ]]; then
  print_error "Commit message cannot be empty"
  exit 1
fi

if [[ ${#HEADER} -gt 72 ]]; then
  print_error "Commit subject is too long (${#HEADER}/72)"
  print_info "Use a short summary in the first line"
  exit 1
fi

# Conventional commits:
#   type(scope): subject
#   type: subject
if ! [[ "$HEADER" =~ ^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._/-]+\))?!?:\ .+ ]]; then
  print_error "Invalid commit message format"
  print_info "Expected: type(scope): summary"
  print_info "Example: feat(hooks): add commit-msg validation"
  print_info "Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  exit 1
fi

print_success "commit-msg format looks good"
