#!/usr/bin/env bash
# Pre-push hook: validates repository health before pushing.

set -euo pipefail

DOTFILES="$(git rev-parse --show-toplevel)"
source "$DOTFILES/lib/output.sh"

FAILED=0
BREW_DRIFT_MSG=""

print_header "Pre-push: Validating Repository"

# ── Brewfile sync ────────────────────────────────────────────────────

print_section "Checking Brewfile sync..."
if command -v brew &>/dev/null; then
  BREW_AUDIT="$DOTFILES/ops/brew-audit.sh"
  if [[ -x "$BREW_AUDIT" ]]; then
    if "$BREW_AUDIT" --check >/dev/null 2>&1; then
      print_success "Brewfiles are in sync"
    else
      BREW_DRIFT_MSG="Brewfiles are out of sync — run: make brew-audit"
      print_warning "Brewfiles are out of sync"
      print_dim "Run: make brew-audit"
    fi
  fi
fi

printf '\n'

# ── Generated docs ───────────────────────────────────────────────────

print_section "Checking generated docs..."
if make -s docs-sync >/dev/null 2>&1; then
  print_success "Generated docs are in sync"
else
  print_error "Generated docs are stale"
  print_info "Run: bash ops/generate-cli-reference.sh"
  FAILED=1
fi

printf '\n'

# ── Untracked shell scripts ─────────────────────────────────────────

print_section "Checking for untracked scripts..."
untracked="$(git -C "$DOTFILES" ls-files --others --exclude-standard | grep -E '\.(sh|bash|zsh)$' || true)"
if [[ -n "$untracked" ]]; then
  print_warning "Found untracked shell scripts:"
  while IFS= read -r file; do
    printf "  "
    print_dim "$file"
  done <<< "$untracked"
else
  print_success "No untracked shell scripts"
fi

printf '\n'

# ── Large files ──────────────────────────────────────────────────────

print_section "Checking for large files..."
large_found=false
while IFS= read -r file; do
  [[ -n "$file" && -f "$file" ]] || continue
  if [[ $(wc -c < "$file") -gt 1048576 ]]; then
    large_found=true
    size=$(du -h "$file" | cut -f1)
    print_error "$file ($size)"
  fi
done < <(git diff --name-only "@{upstream}..HEAD" 2>/dev/null || git diff --name-only HEAD~1..HEAD)

if $large_found; then
  print_error "Large files detected (>1MB)"
  FAILED=1
else
  print_success "No large files detected"
fi

printf '\n'

# ── Branch status ────────────────────────────────────────────────────

print_section "Checking branch status..."
current_branch="$(git -C "$DOTFILES" branch --show-current)"
if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
  if [[ $FAILED -eq 1 ]]; then
    print_error "Pushing to $current_branch with failures"
    FAILED=1
  else
    print_success "Pushing to $current_branch - all checks passed"
  fi
else
  print_info "Pushing to branch: $current_branch"
fi

printf '\n'

# ── Summary ──────────────────────────────────────────────────────────

if [[ $FAILED -eq 1 ]]; then
  print_error "Pre-push checks failed"
  printf '\n'
  exit 1
else
  print_success "All pre-push checks passed - ready to push!"
  if [[ -n "$BREW_DRIFT_MSG" ]]; then
    printf '\n'
    print_warning "$BREW_DRIFT_MSG"
  fi
  printf '\n'
  exit 0
fi
