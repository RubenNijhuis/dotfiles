# shellcheck shell=bash
# Machine-specific shell configuration.
# Generated by `chezmoi apply` from chezmoi/dot_config/shell/local.sh.tmpl.
# Values come from ~/.config/chezmoi/chezmoi.toml (machine-local, untracked).

# ── Paths ──────────────────────────────────────────────────────────────
export OBSIDIAN_VAULT_PATH="{{ .machine.obsidian_vault_path }}"

# ── Celebratix backend (GitHub Packages / NuGet feed) ──────────────────
export GITHUB_USERNAME="{{ .machine.github_username }}"
export NUGET_AUTH_TOKEN="{{ .secrets.nuget_auth_token }}"

# ── MCP / AI tool secrets ──────────────────────────────────────────────
export LINEAR_API_KEY="{{ .secrets.linear_api_key }}"
