# =============================================================================
# Apps Brewfile - GUI applications shared across all profiles
# =============================================================================
# Casks installed on both personal and work machines
# CLI tools go in Brewfile.cli, VS Code extensions in Brewfile.vscode

# -----------------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------------
cask "font-fira-code"            # Monospace font with ligatures
cask "font-fira-code-nerd-font"  # Nerd Font variant (icons for Neovim)
cask "font-hack-nerd-font"            # Patched font with icons
cask "font-symbols-only-nerd-font"  # Standalone Nerd Font icons (fallback)

# -----------------------------------------------------------------------------
# Core Applications
# -----------------------------------------------------------------------------
cask "claude"               # Claude AI desktop app
cask "claude-code"          # Claude Code (coding assistant)
cask "codexbar"             # Menu bar code snippets
cask "ghostty"              # Fast, feature-rich terminal
cask "google-chrome"        # Web browser
cask "lm-studio"            # Local LLM GUI
cask "obsidian"             # Note-taking and knowledge base
cask "raycast"              # Spotlight replacement
cask "visual-studio-code"   # Code editor
