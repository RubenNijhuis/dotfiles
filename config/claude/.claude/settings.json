{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(npm:*)",
      "Bash(bun:*)",
      "Bash(dotnet:*)",
      "Bash(brew:*)",
      "Bash(mise:*)",
      "Bash(stow:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(bash:*)",
      "Bash(perl:*)",
      "Bash(code:*)",
      "Bash(nvim:*)",
      "Bash(bat:*)",
      "Bash(delta:*)",
      "Bash(eza:*)",
      "Bash(fzf:*)",
      "Bash(ls:*)",
      "Bash(test:*)",
      "Bash(cat:*)",
      "Bash(/bin/cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(pgrep:*)",
      "Bash(chmod:*)",
      "Bash(xxd:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(fc-list:*)",
      "Bash(osascript:*)",
      "Bash(timeout:*)",
      "Bash(gtimeout:*)",
      "WebSearch",
      "WebFetch",
      "Skill(commit)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clbtx@celebratix-marketplace": true,
    "figma@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
