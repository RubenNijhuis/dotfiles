{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "16000"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(bun *)",
      "Bash(dotnet *)",
      "Bash(brew *)",
      "Bash(mise *)",
      "Bash(stow *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(bash *)",
      "Bash(perl *)",
      "Bash(code *)",
      "Bash(nvim *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(uname *)",
      "Bash(hostname *)",
      "Bash(pgrep *)",
      "Bash(chmod *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(osascript *)",
      "Bash(timeout *)",
      "Bash(gtimeout *)",
      "WebSearch",
      "WebFetch",
      "Skill(commit)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- .)",
      "Bash(git clean -f *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clbtx@celebratix-marketplace": true,
    "figma@claude-plugins-official": true
  },
  "language": "English",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Aanklooien",
      "Polderen",
      "Frunniken",
      "Tetteren",
      "Mopperen",
      "Husselen",
      "Stuntelen",
      "Keuvelen"
    ]
  },
  "effortLevel": "medium",
  "voiceEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
